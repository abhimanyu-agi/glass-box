OPENAI_API_KEY=your-openai-api-key-here

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=finance_poc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password-here

# Model selection
MODEL_CLASSIFIER=gpt-4o-mini
MODEL_SQL_GEN=gpt-4o
MODEL_NARRATOR=gpt-4o-mini

# Retrieval tuning
RETRIEVAL_TOP_K=8
CONFIDENCE_STRONG=0.3
CONFIDENCE_OK=0.5
CONFIDENCE_WEAK=0.7

# Repair loop
MAX_SQL_REPAIRS=3

LANGCHAIN_TRACING_V2=false
LANGSMITH_TRACING=false

# Superset dashboard URL for iframe embed
SUPERSET_DASHBOARD_URL=http://localhost:8088/superset/dashboard/12/?standalone=3

# FastAPI / JWT
JWT_SECRET_KEY=generate-a-random-string-at-least-32-chars-long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
